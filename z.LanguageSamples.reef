
context TaskList::tt(): boolean
post:
    result = self.TaskStates.isEmpty()

context App::js1: string
post:
    let j: JsonObject = ['A', 'B', 'C']
    let c: integer = j.count
    let s: string
    set(0 .. c-1).forAll(i | 
        s = j[i]
        result = result + s + ' ')

context App::js2: string
post:
    let j: JsonObject = ['A', 'B', 'C']
    j.forAll(s: string | result = result + s + ' ')